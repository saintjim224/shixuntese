# OpenAI-compatible chat service. Leave RAG_API_KEY empty to use local retrieval fallback.
RAG_API_KEY=
RAG_BASE_URL=https://open.bigmodel.cn/api/paas/v4
RAG_CHAT_MODEL=glm-4-flash
RAG_EMBED_MODEL=embedding-3
RAG_VISION_MODEL=glm-4v-flash
RAG_MAX_UPLOAD_MB=10
RAG_ALLOWED_ORIGINS=*

# GLM/Zhipu example:
# RAG_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# RAG_CHAT_MODEL=glm-4-flash
# RAG_EMBED_MODEL=embedding-3
# RAG_VISION_MODEL=glm-4v-flash

# Python RAG service.
RAG_HOST=127.0.0.1
RAG_PORT=8010

# Q_ITOffer MySQL database. These defaults match server/src/main/resources/db.properties.
QITOFFER_DB_HOST=127.0.0.1
QITOFFER_DB_PORT=3307
QITOFFER_DB_USER=qitoffer_app
QITOFFER_DB_PASSWORD=Qitoffer@2026
QITOFFER_DB_NAME=q_itoffer
