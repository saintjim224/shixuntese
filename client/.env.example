# Java Servlet API base. Leave empty in Tomcat deployment because context path is detected automatically.
VITE_API_BASE=

# Python RAG service used by /rag.
VITE_RAG_BASE_URL=http://127.0.0.1:8010

# AMap JSAPI v2.0 used by /map. Copy real values to client/.env.local only.
VITE_AMAP_KEY=your-amap-web-jsapi-key
VITE_AMAP_SECURITY_JS_CODE=your-amap-security-js-code
VITE_AMAP_SERVICE_HOST=
